# Dependencies
node_modules/

# Build output (root-anchored so nested dirs like docs/build/ aren't ignored).
# Everything in output/ is regenerable via `pnpm pipeline`, but the book PDF
# itself is tracked: it is the shipped deliverable.
/output/*
!/output/react-pdf-ai-builders-guide.pdf
/dist/
/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

